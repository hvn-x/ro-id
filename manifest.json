{
  "manifest_version": 3,
  "name": "Ro-ID",
  "version": "1.1.0",
  "description": "Quickly copy Roblox user IDs from profile pages and menus.",
  "permissions": ["clipboardWrite"],
  "content_scripts": [
    {
      "matches": ["https://www.roblox.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://www.roblox.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
